<Application x:Class="StudentReportGenerator.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Application.Resources>
        <!-- Accessibility: swapped by SettingsViewModel.ApplyFontPreferences (dyslexia-friendly
             font toggle and text-size scaling) -->
        <FontFamily x:Key="AppFontFamily">Segoe UI</FontFamily>
        <sys:Double x:Key="AppFontSize">13</sys:Double>

        <!-- Light-theme defaults. SettingsViewModel.ApplyTheme swaps every key below
             for its dark counterpart, so all UI colors MUST resolve through these
             resources (no hardcoded hex in views). -->
        <SolidColorBrush x:Key="ThemeAppBg" Color="#FFFAFAFA"/>
        <SolidColorBrush x:Key="ThemeCardBg" Color="White"/>
        <SolidColorBrush x:Key="ThemeText" Color="#FF333333"/>
        <SolidColorBrush x:Key="ThemeMutedText" Color="#FF616161"/>
        <SolidColorBrush x:Key="ThemeBorder" Color="#FFDDDDDD"/>
        <SolidColorBrush x:Key="ThemeInputBg" Color="White"/>
        <SolidColorBrush x:Key="ThemePreviewBg" Color="#FFF9F9F9"/>

        <SolidColorBrush x:Key="ThemeButtonBg" Color="#FFEEEEEE"/>
        <SolidColorBrush x:Key="ThemeButtonHoverBg" Color="#FFDDDDDD"/>
        <SolidColorBrush x:Key="ThemePrimaryBtnBg" Color="#FF4CAF50"/>
        <SolidColorBrush x:Key="ThemePrimaryBtnHoverBg" Color="#FF43A047"/>

        <SolidColorBrush x:Key="ThemeDangerBg" Color="#FFFFEBEE"/>
        <SolidColorBrush x:Key="ThemeDangerText" Color="#FFD32F2F"/>
        <SolidColorBrush x:Key="ThemeDangerStrongBg" Color="#FFF44336"/>
        <SolidColorBrush x:Key="ThemeInfoBg" Color="#FFE0F7FA"/>
        <SolidColorBrush x:Key="ThemeInfoText" Color="#FF00838F"/>
        <SolidColorBrush x:Key="ThemeInfoAccent" Color="#FF1E88E5"/>
        <SolidColorBrush x:Key="ThemeWarningBg" Color="#FFFFF3E0"/>
        <SolidColorBrush x:Key="ThemeWarningText" Color="#FFE65100"/>
        <SolidColorBrush x:Key="ThemeWarningAccent" Color="#FFF57C00"/>
        <SolidColorBrush x:Key="ThemeSuccessBg" Color="#FFE8F5E9"/>
        <SolidColorBrush x:Key="ThemeSuccessText" Color="#FF2E7D32"/>
        <SolidColorBrush x:Key="ThemeSuccessAccent" Color="#FF43A047"/>
        <SolidColorBrush x:Key="ThemeAccentBlueBg" Color="#FF1976D2"/>

        <SolidColorBrush x:Key="ThemeMetricCardBg" Color="#FFF5F5F5"/>
        <SolidColorBrush x:Key="ThemeMetricIndigoBg" Color="#FFE8EAF6"/>
        <SolidColorBrush x:Key="ThemeMetricNvidiaBg" Color="#FFE1F5FE"/>
        <SolidColorBrush x:Key="ThemeMetricNvidiaText" Color="#FF01579B"/>
        <SolidColorBrush x:Key="ThemeMetricGeminiBg" Color="#FFE0F7FA"/>
        <SolidColorBrush x:Key="ThemeMetricGeminiText" Color="#FF006064"/>
        <SolidColorBrush x:Key="ThemeMetricOpenAiBg" Color="#FFF3E5F5"/>
        <SolidColorBrush x:Key="ThemeMetricOpenAiText" Color="#FF4A148C"/>
        <SolidColorBrush x:Key="ThemeMetricClaudeBg" Color="#FFFFF3E0"/>
        <SolidColorBrush x:Key="ThemeMetricClaudeText" Color="#FFE65100"/>
    </Application.Resources>
</Application>
