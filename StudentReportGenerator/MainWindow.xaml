<Window x:Class="StudentReportGenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Student Report Generator" Height="800" Width="1300"
        Background="{DynamicResource ThemeAppBg}" Foreground="{DynamicResource ThemeText}">

    <Window.Resources>
        <!-- SPRINT 23/24: DYNAMIC THEME ENGINE -->
        <SolidColorBrush x:Key="ThemeAppBg" Color="#FFFAFAFA"/>
        <SolidColorBrush x:Key="ThemeCardBg" Color="White"/>
        <SolidColorBrush x:Key="ThemeText" Color="#FF333333"/>
        <SolidColorBrush x:Key="ThemeMutedText" Color="Gray"/>
        <SolidColorBrush x:Key="ThemeBorder" Color="#FFDDDDDD"/>
        <SolidColorBrush x:Key="ThemeInputBg" Color="White"/>
        <SolidColorBrush x:Key="ThemePreviewBg" Color="#FFF9F9F9"/>

        <!-- Global Styles applying the Theme -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource ThemeInputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{DynamicResource ThemeInputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource ThemeCardBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
        </Style>

        <!-- Card Styles -->
        <Style x:Key="ModernCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeCardBg}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="25"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFF5F5F5"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="5,5,5,15"/>
        </Style>

        <!-- Button Styles -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFEEEEEE"/>
            <Setter Property="Foreground" Value="#FF333333"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="17.5" Padding="20,0,20,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFDDDDDD"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ModernPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#FF4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF43A047"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainLayoutGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.3*"/>
            <ColumnDefinition Width="1.4*"/>
            <ColumnDefinition Width="1.0*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP NAV -->
        <Border x:Name="TopNavBar" Grid.Row="0" Grid.ColumnSpan="3" Background="#FF392A4C" Padding="20,0,20,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image x:Name="imgSchoolLogo" Height="40" Margin="0,0,15,0" Visibility="Collapsed" Stretch="Uniform"/>
                    <TextBlock x:Name="lblMainTitle" Text="AI STUDENT REPORT GENERATOR" FontWeight="Bold" FontSize="18" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text=" - v24.0 (Expanded DB Context)" FontSize="12" Foreground="#FFCCCCCC" Margin="5,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- COLUMN 1: DYNAMIC INPUT CARD -->
        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource ModernCardStyle}" x:Name="Card1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock x:Name="lblActiveModule" Text="ACTIVE MODULE:" FontWeight="Bold" Foreground="#FF9C27B0" Margin="0,0,0,5" FontSize="11"/>
                    <ComboBox x:Name="cmbNavigation" Height="40" FontSize="14" FontWeight="SemiBold" Padding="10,8" SelectionChanged="cmbNavigation_SelectionChanged">
                        <ComboBoxItem Content="📝 Single Report Generator" IsSelected="True"/>
                        <ComboBoxItem Content="📚 Batch Mode Processing"/>
                        <ComboBoxItem Content="⚖️ Compare AI Models"/>
                        <ComboBoxItem Content="👤 Profile &amp; General Settings"/>
                        <ComboBoxItem Content="🧠 AI Engine &amp; Prompts"/>
                        <ComboBoxItem Content="📊 Analytics Dashboard"/>
                    </ComboBox>
                    <Rectangle Height="1" Fill="{DynamicResource ThemeBorder}" Margin="0,15,0,0"/>
                </StackPanel>

                <!-- MODULE 1: SINGLE REPORT -->
                <ScrollViewer x:Name="gridSingleReport" Grid.Row="1" VerticalScrollBarVisibility="Auto" Visibility="Visible">
                    <StackPanel Margin="0,0,10,10">
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Student Name:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBlock Grid.Column="1" Text="Class/Group:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="cmbStudentDatabase" IsEditable="True" Height="35" Padding="5" Margin="0,0,8,0" FontSize="13" SelectionChanged="cmbStudentDatabase_SelectionChanged"/>
                            <TextBox x:Name="txtStudentClass" Grid.Column="1" Height="35" Padding="8" FontSize="13" Margin="0,0,8,0"/>
                            <Button x:Name="btnSaveStudent" Grid.Column="2" Content="Save" Style="{StaticResource ModernButtonStyle}" Width="Auto" Padding="15,0" Height="35" Margin="0,0,5,0" Click="btnSaveStudent_Click"/>
                            <Button x:Name="btnDeleteStudent" Grid.Column="3" Content="Delete" Style="{StaticResource ModernButtonStyle}" Background="#FFFFEBEE" Foreground="#FFD32F2F" Width="Auto" Padding="15,0" Height="35" Click="btnDeleteStudent_Click"/>
                        </Grid>

                        <!-- SPRINT 24: EXPANDED CONTEXT GRID -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="1.5*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Target Grade:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtTargetGrade" Height="35" Padding="8" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Support Needs/SEN:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtSupportNeeds" Height="35" Padding="8" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Parent Email:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtParentEmail" Height="35" Padding="8" FontSize="13"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                            <Button x:Name="btnImportRoster" Content="📁 Import Roster (.csv)" Style="{StaticResource ModernButtonStyle}" Background="#FFE0F7FA" Foreground="#FF0097A7" Height="28" Padding="10,0" Margin="0,0,10,0" Click="btnImportRoster_Click"/>
                            <Button x:Name="btnViewStudentHistory" Content="🕒 View Student History" Style="{StaticResource ModernButtonStyle}" Background="#FFF3E0" Foreground="#FFE65100" Height="28" Padding="10,0" Click="btnViewStudentHistory_Click"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,25">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Target Word Count:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <ComboBox x:Name="cmbWordCount" Height="35" Padding="5" FontSize="13">
                                    <ComboBoxItem Content="~100 Words (Short)" Tag="100"/>
                                    <ComboBoxItem Content="~150 Words (Standard)" Tag="150" IsSelected="True"/>
                                    <ComboBoxItem Content="~200 Words (Detailed)" Tag="200"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Framework / Tone:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="cmbFramework" Height="35" Padding="5" FontSize="13" Margin="0,0,5,0"/>
                                    <Button x:Name="btnPreviewTone" Grid.Column="1" Content="Preview Tone" Style="{StaticResource ModernButtonStyle}" Width="90" Height="35" Click="btnPreviewTone_Click"/>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <Border Background="{DynamicResource ThemePreviewBg}" x:Name="boxReportContents" CornerRadius="8" Padding="15" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="REPORT CONTENTS" FontWeight="Bold" Foreground="#4CAF50" Margin="0,0,0,10"/>
                                <TextBlock Text="Curriculum Topic:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="cmbCurriculum" IsEditable="True" Height="35" Padding="5" Margin="0,0,8,0" FontSize="13"/>
                                    <Button x:Name="btnSaveCurriculum" Grid.Column="1" Content="Save Topic" Style="{StaticResource ModernButtonStyle}" Width="Auto" Padding="15,0" Height="35" Margin="0,0,5,0" Click="btnSaveCurriculum_Click"/>
                                    <Button x:Name="btnDeleteCurriculum" Grid.Column="2" Content="Delete" Style="{StaticResource ModernButtonStyle}" Background="#FFFFEBEE" Foreground="#FFD32F2F" Width="Auto" Padding="15,0" Height="35" Click="btnDeleteCurriculum_Click"/>
                                </Grid>

                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                        <TextBlock Text="Timekeeping:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <RadioButton x:Name="rbTime1" GroupName="Timekeeping" Content="100% attendance" IsChecked="True" Margin="0,0,0,6"/>
                                        <RadioButton x:Name="rbTime2" GroupName="Timekeeping" Content="Occasional absences" Margin="0,0,0,6"/>
                                        <RadioButton x:Name="rbTime3" GroupName="Timekeeping" Content="Unauthorised absences" Margin="0,0,0,6"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Contributions:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <RadioButton x:Name="rbContribute1" GroupName="Contributions" Content="Enthusiastic" IsChecked="True" Margin="0,0,0,6"/>
                                        <RadioButton x:Name="rbContribute2" GroupName="Contributions" Content="Occasional" Margin="0,0,0,6"/>
                                        <RadioButton x:Name="rbContribute3" GroupName="Contributions" Content="Rare, high quality" Margin="0,0,0,6"/>
                                        <RadioButton x:Name="rbContribute4" GroupName="Contributions" Content="Never contributes" Margin="0,0,0,6"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Additional Custom Notes (Optional):" FontWeight="SemiBold" Margin="0,10,0,5"/>
                                <Grid Height="80">
                                    <TextBox x:Name="txtNotes" SpellCheck.IsEnabled="True" TextWrapping="Wrap" AcceptsReturn="True" Padding="8" FontSize="13"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Button x:Name="btnGenerate" Content="Generate Single Report" Height="50" FontSize="14" Style="{StaticResource ModernPrimaryButtonStyle}" Click="btnGenerate_Click" Margin="0,5,0,0"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- MODULE 2: BATCH MODE -->
                <StackPanel x:Name="gridBatchMode" Grid.Row="1" Visibility="Collapsed" Margin="0,0,10,10">
                    <TextBlock Text="SPREADSHEET IMPORT" FontWeight="Bold" Foreground="#FFFF5722" Margin="0,10,0,5"/>
                    <TextBlock Text="Upload a .csv file (Column A = Name, Column B = Notes) or paste manually below." Foreground="{DynamicResource ThemeMutedText}" TextWrapping="Wrap" FontSize="13" Margin="0,0,0,20"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Batch Data:" FontWeight="SemiBold" VerticalAlignment="Bottom" x:Name="lblCol2_1"/>
                        <Button x:Name="btnImportCSV" Grid.Column="1" Content="Upload .CSV List" Style="{StaticResource ModernButtonStyle}" Background="#FFE0F7FA" Foreground="#FF0097A7" Width="130" Height="30" Click="btnImportCSV_Click"/>
                    </Grid>
                    <Grid Height="280">
                        <TextBox x:Name="txtBatchData" SpellCheck.IsEnabled="True" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,15" Padding="10" VerticalScrollBarVisibility="Auto" FontSize="13"/>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="btnGenerateBatch" Grid.Column="0" Content="Process Entire Class" Height="45" Style="{StaticResource ModernPrimaryButtonStyle}" Background="#FF00BCD4" Click="btnGenerateBatch_Click"/>
                        <Button x:Name="btnCancelBatch" Grid.Column="0" Content="🛑 Stop Generation" Height="45" Style="{StaticResource ModernPrimaryButtonStyle}" Background="#FFF44336" Click="btnCancelBatch_Click" Visibility="Collapsed"/>
                        <Button x:Name="btnExportBatchWord" Grid.Column="2" Content="Export Batch to .docx" Height="45" Style="{StaticResource ModernPrimaryButtonStyle}" Background="#FF1976D2" Click="btnExportBatchWord_Click"/>
                    </Grid>
                </StackPanel>

                <!-- MODULE 3: COMPARE MODELS -->
                <StackPanel x:Name="gridCompare" Grid.Row="1" Visibility="Collapsed" Margin="0,0,10,10">
                    <TextBlock Text="MODEL DEMO SUITE" FontWeight="Bold" Foreground="#9C27B0" Margin="0,10,0,5"/>
                    <TextBlock Text="Generate the exact same report simultaneously using two different AI models to compare quality." Foreground="{DynamicResource ThemeMutedText}" TextWrapping="Wrap" FontSize="13" Margin="0,0,0,20"/>
                    <TextBlock Text="Student Name:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtCompareName" Height="35" Margin="0,0,0,20" Padding="8" FontSize="13"/>
                    <TextBlock Text="Rough Notes:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <Grid Height="120">
                        <TextBox x:Name="txtCompareNotes" SpellCheck.IsEnabled="True" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,15" Padding="8" FontSize="13"/>
                    </Grid>
                    <Grid Margin="0,10,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Provider 1:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <ComboBox x:Name="cmbCompare1" Height="35" Padding="5" FontSize="13">
                                <ComboBoxItem Content="Google Gemini" IsSelected="True"/>
                                <ComboBoxItem Content="ChatGPT (OpenAI)"/>
                                <ComboBoxItem Content="Claude (Anthropic)"/>
                                <ComboBoxItem Content="NVIDIA NIM (Free)"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Provider 2:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <ComboBox x:Name="cmbCompare2" Height="35" Padding="5" FontSize="13">
                                <ComboBoxItem Content="Google Gemini"/>
                                <ComboBoxItem Content="ChatGPT (OpenAI)"/>
                                <ComboBoxItem Content="Claude (Anthropic)"/>
                                <ComboBoxItem Content="NVIDIA NIM (Free)" IsSelected="True"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                    <Button x:Name="btnCompare" Content="Run Side-by-Side Generation" Height="50" FontSize="14" Style="{StaticResource ModernPrimaryButtonStyle}" Background="#FF9C27B0" Click="btnCompare_Click"/>
                </StackPanel>

                <!-- MODULE 4: PROFILE SETTINGS -->
                <Grid x:Name="gridProfileSettings" Grid.Row="1" Visibility="Collapsed">
                    <ScrollViewer x:Name="scrollProfileSettings" VerticalScrollBarVisibility="Auto" Visibility="Visible">
                        <StackPanel Margin="0,0,10,10">
                            <TextBlock Text="PROFILE &amp; BRANDING" FontWeight="Bold" Foreground="#4CAF50" Margin="0,0,0,10"/>
                            <CheckBox x:Name="chkDarkMode" Content="Enable Dark Mode" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,15" Checked="chkDarkMode_Changed" Unchecked="chkDarkMode_Changed"/>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Teacher Name:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBox x:Name="txtSetTeacherName" Height="35" Padding="8" FontSize="13"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="School Name:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBox x:Name="txtSetSchoolName" Height="35" Padding="8" FontSize="13"/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,0,0,25">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="School Logo (Optional):" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <Button x:Name="btnUploadLogo" Content="Upload Image (.png / .jpg)" Style="{StaticResource ModernButtonStyle}" Height="35" Click="btnUploadLogo_Click"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="UI Theme Color:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="cmbThemeColor" Height="35" Padding="8" FontSize="13" SelectionChanged="cmbThemeColor_SelectionChanged">
                                        <ComboBoxItem Content="Deep Purple (Default)" Tag="#FF392A4C"/>
                                        <ComboBoxItem Content="Navy Blue" Tag="#FF0A192F"/>
                                        <ComboBoxItem Content="Forest Green" Tag="#FF1B3822"/>
                                        <ComboBoxItem Content="Burgundy Red" Tag="#FF4A1525"/>
                                        <ComboBoxItem Content="Slate Dark" Tag="#FF263238"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="EMAIL INTEGRATION (SMTP)" FontWeight="Bold" Foreground="#FF9800" Margin="0,10,0,10"/>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Your Email Address:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBox x:Name="txtSmtpEmail" Height="35" Padding="8" FontSize="13"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Email App Password:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <PasswordBox x:Name="pwdSmtpPassword" Height="35" Padding="8"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="*Note: You may need an 'App Password' from Gmail/Outlook, not your normal login password." FontStyle="Italic" Foreground="{DynamicResource ThemeMutedText}" FontSize="11" Margin="0,0,0,25"/>

                            <TextBlock Text="SECURITY" FontWeight="Bold" Foreground="#F44336" Margin="0,10,0,10"/>
                            <TextBlock Text="Master Password (Protects Settings):" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <PasswordBox x:Name="pwdMasterSet" Height="35" Padding="8" Margin="0,0,0,25"/>

                            <Button x:Name="btnSaveProfileSettings" Content="Save Profile Settings" Height="50" FontSize="14" Style="{StaticResource ModernPrimaryButtonStyle}" Background="#FF4CAF50" Click="btnSaveSettings_Click" Margin="0,10,0,0"/>
                        </StackPanel>
                    </ScrollViewer>
                    <Border x:Name="brdProfileLock" Background="{DynamicResource ThemeAppBg}" Visibility="Collapsed" Panel.ZIndex="10">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                            <TextBlock Text="🔒 Settings Locked" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Enter your master password to access your Profile Settings." Foreground="{DynamicResource ThemeMutedText}" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                            <PasswordBox x:Name="pwdUnlockProfile" Height="40" Width="280" Padding="8" Margin="0,0,0,20"/>
                            <Button Content="Unlock Settings" Height="45" Width="280" FontSize="14" Style="{StaticResource ModernPrimaryButtonStyle}" Click="btnUnlockSettings_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- MODULE 5: AI ENGINE SETTINGS -->
                <Grid x:Name="gridAiSettings" Grid.Row="1" Visibility="Collapsed">
                    <ScrollViewer x:Name="scrollAiSettings" VerticalScrollBarVisibility="Auto" Visibility="Visible">
                        <StackPanel Margin="0,0,10,10">
                            <TextBlock Text="AI ENGINE CONFIGURATION" FontWeight="Bold" Foreground="#2196F3" Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Provider:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="cmbAiProvider" Height="35" SelectionChanged="cmbAiProvider_SelectionChanged">
                                        <ComboBoxItem Content="NVIDIA NIM (Free)"/>
                                        <ComboBoxItem Content="Google Gemini"/>
                                        <ComboBoxItem Content="ChatGPT (OpenAI)"/>
                                        <ComboBoxItem Content="Claude (Anthropic)"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Model Tier:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="cmbModelTier" Height="35" SelectionChanged="cmbModelTier_SelectionChanged"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="API Key:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,25">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="lblDynamicApiKey" Text="NVIDIA Key:" VerticalAlignment="Center"/>
                                <PasswordBox x:Name="pwdDynamicApiKey" Grid.Column="1" Height="35" Padding="8" PasswordChanged="pwdDynamicApiKey_PasswordChanged"/>
                            </Grid>

                            <TextBlock Text="PROMPT TEMPLATES" FontWeight="Bold" Foreground="#9C27B0" Margin="0,10,0,10"/>
                            <TextBlock Text="Label/Name (e.g., SEN Report):" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtFrameworkName" Height="35" Padding="8" Margin="0,0,0,15" FontSize="13"/>
                            <TextBlock Text="Detailed Prompt Instructions:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtFrameworkInstruction" SpellCheck.IsEnabled="True" TextWrapping="Wrap" AcceptsReturn="True" Height="70" Padding="8" Margin="0,0,0,10" FontSize="13"/>
                            <Button x:Name="btnAddFramework" Content="Add Custom Template" Style="{StaticResource ModernButtonStyle}" Height="35" Click="btnAddFramework_Click"/>

                            <Button x:Name="btnSaveAiSettings" Content="Save AI Configurations" Height="50" FontSize="14" Style="{StaticResource ModernPrimaryButtonStyle}" Background="#FF2196F3" Click="btnSaveSettings_Click" Margin="0,30,0,0"/>
                        </StackPanel>
                    </ScrollViewer>
                    <Border x:Name="brdAiLock" Background="{DynamicResource ThemeAppBg}" Visibility="Collapsed" Panel.ZIndex="10">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                            <TextBlock Text="🔒 Settings Locked" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Enter your master password to access AI Keys." Foreground="{DynamicResource ThemeMutedText}" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                            <PasswordBox x:Name="pwdUnlockAi" Height="40" Width="280" Padding="8" Margin="0,0,0,20"/>
                            <Button Content="Unlock Settings" Height="45" Width="280" FontSize="14" Style="{StaticResource ModernPrimaryButtonStyle}" Click="btnUnlockSettings_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- MODULE 6: DASHBOARD -->
                <ScrollViewer x:Name="gridDashboard" Grid.Row="1" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,10,10">
                        <TextBlock Text="LIFETIME ROI METRICS" FontWeight="Bold" Foreground="#3F51B5" Margin="0,10,0,10"/>
                        <TextBlock Text="Total administrative hours saved using AI." Foreground="{DynamicResource ThemeMutedText}" TextWrapping="Wrap" FontSize="13" Margin="0,0,0,15"/>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}" Background="#E8EAF6" Margin="0,0,5,0">
                                <StackPanel>
                                    <TextBlock Text="Admin Hours Saved" FontSize="14" FontWeight="SemiBold" Foreground="#3F51B5"/>
                                    <TextBlock x:Name="lblHoursSaved" Text="0.0 hrs" FontSize="36" FontWeight="Bold" Foreground="#303F9F" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}" Background="#E8F5E9" Margin="5,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Total Tokens Est." FontSize="14" FontWeight="SemiBold" Foreground="#2E7D32"/>
                                    <TextBlock x:Name="lblTokensUsed" Text="0" FontSize="36" FontWeight="Bold" Foreground="#1B5E20" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <TextBlock Text="API USAGE BY PROVIDER" FontWeight="Bold" Foreground="#009688" Margin="0,10,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}" Background="#E1F5FE">
                                <StackPanel>
                                    <TextBlock Text="NVIDIA" FontSize="12" Foreground="#0277BD"/>
                                    <TextBlock x:Name="lblNvidiaCount" Text="0" FontSize="24" FontWeight="Bold" Foreground="#01579B"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}" Background="#E0F7FA">
                                <StackPanel>
                                    <TextBlock Text="Gemini" FontSize="12" Foreground="#00838F"/>
                                    <TextBlock x:Name="lblGeminiCount" Text="0" FontSize="24" FontWeight="Bold" Foreground="#006064"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}" Background="#F3E5F5">
                                <StackPanel>
                                    <TextBlock Text="OpenAI" FontSize="12" Foreground="#6A1B9A"/>
                                    <TextBlock x:Name="lblOpenAiCount" Text="0" FontSize="24" FontWeight="Bold" Foreground="#4A148C"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="3" Style="{StaticResource MetricCardStyle}" Background="#FFF3E0">
                                <StackPanel>
                                    <TextBlock Text="Claude" FontSize="12" Foreground="#EF6C00"/>
                                    <TextBlock x:Name="lblClaudeCount" Text="0" FontSize="24" FontWeight="Bold" Foreground="#E65100"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- COLUMN 2: ACTIVE OUTPUT -->
        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource ModernCardStyle}" x:Name="Card2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="GENERATED REPORT" FontWeight="Bold" FontSize="16" Foreground="#FF00BCD4"/>
                    <TextBlock x:Name="lblStatus" Text="Ready." FontSize="12" Margin="0,4,0,0" Foreground="{DynamicResource ThemeMutedText}"/>
                    <ProgressBar x:Name="prgLoading" Height="4" IsIndeterminate="True" Visibility="Collapsed" Margin="0,10,0,0" Foreground="#FF00BCD4" Background="Transparent" BorderThickness="0"/>
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="0" x:Name="colCompareRight"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtOutput" SpellCheck.IsEnabled="True" Grid.Column="0" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="False" FontSize="14" Padding="15"/>
                    <TextBox x:Name="txtCompareOutput2" Background="{DynamicResource ThemePreviewBg}" SpellCheck.IsEnabled="True" Grid.Column="1" Margin="10,0,0,0" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="False" FontSize="14" Padding="15" Visibility="Collapsed"/>
                </Grid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button x:Name="btnCopy" Content="Copy text" Style="{StaticResource ModernButtonStyle}" Margin="0,0,10,0" Click="btnCopy_Click"/>
                    <Button x:Name="btnEmailReport" Content="✉️ Email to Parent" Style="{StaticResource ModernButtonStyle}" Background="#FFFFE0B2" Foreground="#FFE65100" Margin="0,0,10,0" Click="btnEmailReport_Click"/>
                    <Button x:Name="btnSavePdf" Content="Export .pdf" Style="{StaticResource ModernPrimaryButtonStyle}" Background="#FFF44336" Margin="0,0,10,0" Click="btnSavePdf_Click"/>
                    <Button x:Name="btnSaveWord" Content="Export .docx" Style="{StaticResource ModernPrimaryButtonStyle}" Background="#FF1976D2" Margin="0,0,10,0" Click="btnSaveWord_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- COLUMN 3: HISTORY -->
        <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource ModernCardStyle}" x:Name="Card3">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1.5*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="SESSION HISTORY" FontWeight="Bold" FontSize="16" Foreground="#FF9C27B0" VerticalAlignment="Center"/>
                        <Button x:Name="btnShowAllHistory" Grid.Column="1" Content="Show All" Style="{StaticResource ModernButtonStyle}" Height="25" Padding="10,0" Visibility="Collapsed" Click="btnShowAllHistory_Click"/>
                    </Grid>
                    <TextBlock Text="Right-click a report for options." FontSize="12" Margin="0,4,0,10" Foreground="{DynamicResource ThemeMutedText}"/>
                </StackPanel>

                <ListBox x:Name="lstHistory" Grid.Row="1" DisplayMemberPath="DisplayText" FontSize="14" SelectionChanged="lstHistory_SelectionChanged" Margin="0,0,0,15">
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="✏️ Edit in Main Editor" Click="MenuItem_EditHistory_Click"/>
                            <MenuItem Header="🗑️ Permanently Delete" Click="MenuItem_DeleteHistory_Click"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                </ListBox>

                <Grid Grid.Row="2" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="READ-ONLY PREVIEW" FontWeight="Bold" FontSize="12" Foreground="{DynamicResource ThemeMutedText}" VerticalAlignment="Center"/>
                    <Button x:Name="btnCompareHistory" Grid.Column="1" Content="Compare w/ Editor" Style="{StaticResource ModernButtonStyle}" Height="25" Padding="10,0" Click="btnCompareHistory_Click"/>
                </Grid>

                <TextBox x:Name="txtHistoryPreview" Background="{DynamicResource ThemePreviewBg}" Grid.Row="3" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True" FontSize="13" Padding="15"/>
            </Grid>
        </Border>

        <!-- FULL SCREEN WELCOME OVERLAY -->
        <Border x:Name="overlayWelcome" Grid.Row="0" Grid.RowSpan="2" Grid.ColumnSpan="3" Background="#F2000000" Visibility="Visible" Panel.ZIndex="100">
            <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="15" Width="750" Height="620" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="40">
                <StackPanel>
                    <TextBlock Text="👋 Welcome to AI Report Generator" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource ThemeText}" TextAlignment="Center" Margin="0,0,0,10"/>
                    <StackPanel x:Name="pnlProfileSetup" Margin="0,10,0,20">
                        <TextBlock Text="Let's set up your teacher profile." FontSize="16" Foreground="{DynamicResource ThemeMutedText}" TextAlignment="Center" Margin="0,0,0,20"/>
                        <Grid Width="400" HorizontalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Teacher Sign-off (e.g. Mr. Smith):" FontWeight="SemiBold" Margin="0,0,0,5" Grid.Row="0"/>
                            <TextBox x:Name="txtWelcomeTeacherName" Height="35" Padding="8" FontSize="14" Margin="0,0,0,15" Grid.Row="1"/>
                            <TextBlock Text="School Name:" FontWeight="SemiBold" Margin="0,0,0,5" Grid.Row="2"/>
                            <TextBox x:Name="txtWelcomeSchoolName" Height="35" Padding="8" FontSize="14" Grid.Row="3"/>
                        </Grid>
                    </StackPanel>
                    <StackPanel x:Name="pnlWelcomeBack" Visibility="Collapsed" Margin="0,10,0,20">
                        <TextBlock x:Name="lblWelcomeBack" Text="Welcome back, Teacher!" FontSize="22" FontWeight="Bold" Foreground="#4CAF50" TextAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock Text="Write an entire class worth of reports in under 5 minutes." FontSize="14" Foreground="{DynamicResource ThemeMutedText}" TextAlignment="Center" Margin="0,0,0,10"/>
                        <Button x:Name="btnEditProfile" Content="Edit Profile Info" Style="{StaticResource ModernButtonStyle}" Background="Transparent" Foreground="#2196F3" Height="25" Click="btnEditProfile_Click" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <Grid Margin="0,10,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="10">
                            <TextBlock Text="⚙️ Step 1" FontSize="18" FontWeight="Bold" Foreground="#2196F3" TextAlignment="Center" Margin="0,0,0,5"/>
                            <TextBlock Text="Open Settings and paste your API Key." Foreground="{DynamicResource ThemeText}" TextWrapping="Wrap" TextAlignment="Center" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10">
                            <TextBlock Text="📝 Step 2" FontSize="18" FontWeight="Bold" Foreground="#4CAF50" TextAlignment="Center" Margin="0,0,0,5"/>
                            <TextBlock Text="Add a student to the DB and pick a Topic." Foreground="{DynamicResource ThemeText}" TextWrapping="Wrap" TextAlignment="Center" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="10">
                            <TextBlock Text="🚀 Step 3" FontSize="18" FontWeight="Bold" Foreground="#FF9800" TextAlignment="Center" Margin="0,0,0,5"/>
                            <TextBlock Text="Click the radio buttons to build the profile and hit Generate." Foreground="{DynamicResource ThemeText}" TextWrapping="Wrap" TextAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                    <Border Background="#FFF3E0" CornerRadius="8" Padding="15" Margin="0,0,0,25">
                        <TextBlock Text="🔒 Privacy Promise: This application is 100% offline. Student names are automatically scrubbed from the AI prompt and never leave your local hard drive." TextWrapping="Wrap" Foreground="#E65100" FontWeight="SemiBold" TextAlignment="Center" FontSize="12"/>
                    </Border>
                    <Button x:Name="btnEnterApp" Content="Save &amp; Enter Application" Height="45" Width="300" FontSize="16" Style="{StaticResource ModernPrimaryButtonStyle}" Click="btnEnterApp_Click"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>