                                    <TextBlock Text="FacultyFlow AI — Student Report Generator" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{Binding AppVersionDisplay}" FontSize="12" Foreground="{DynamicResource ThemeMutedText}" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding AppBuildDateDisplay}" FontSize="12" Foreground="{DynamicResource ThemeMutedText}" Margin="0,2,0,0"/>
                                    <TextBlock Text="Support: jeremy.m.everitt@googlemail.com" FontSize="12" Foreground="{DynamicResource ThemeMutedText}" Margin="0,2,0,0"/>
                                    <TextBlock Text="Please quote the version number above when reporting a problem." FontSize="11" FontStyle="Italic" Foreground="{DynamicResource ThemeMutedText}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource ModernCardStyle}" x:Name="Card2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="REPORT PREVIEW" FontWeight="Bold" FontSize="16" Foreground="{Binding SettingsVM.NavBarBackground}"/>
                        <TextBlock Grid.Column="1" Text="{Binding ReadingLevelDisplay}" FontSize="11" Foreground="{DynamicResource ThemeMutedText}" VerticalAlignment="Center"
                                   ToolTip="A rough guide to how easy this report is for parents to read"/>
                    </Grid>
                    <TextBlock Text="{Binding StatusText}" FontSize="12" Margin="0,4,0,0" Foreground="{DynamicResource ThemeMutedText}"/>
                    <ProgressBar Height="4" IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" Margin="0,10,0,0" Foreground="{Binding SettingsVM.NavBarBackground}" Background="Transparent" BorderThickness="0"/>

                    <WrapPanel Margin="0,8,0,0">
                        <Button Command="{Binding SimplifyForParentsCommand}" Style="{StaticResource ModernButtonStyle}" Height="26" Padding="8,0" FontSize="11" Margin="0,0,6,4"
                                ToolTip="Rewrite this report in plainer language for parents (shown side-by-side)">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ButtonIconStyle}" Text="&#xE8C1;" FontSize="11"/>
                                <TextBlock Text="Simplify for Parents"/>
                            </StackPanel>
                        </Button>
                        <ComboBox SelectedValue="{Binding SelectedTranslationLanguage, Mode=TwoWay}" ItemsSource="{Binding TranslationLanguages}" Height="26" Width="110" FontSize="11" Margin="0,0,4,4"
                                  AutomationProperties.Name="Translation language"/>
                        <Button Command="{Binding TranslateReportCommand}" Style="{StaticResource ModernButtonStyle}" Height="26" Padding="8,0" FontSize="11" Margin="0,0,6,4"
                                ToolTip="Machine-translate this report for EAL families (clearly labelled; shown side-by-side)">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ButtonIconStyle}" Text="&#xE775;" FontSize="11"/>
                                <TextBlock Text="Translate"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ReadAloudCommand}" Style="{StaticResource ModernButtonStyle}" Height="26" Padding="8,0" FontSize="11" Margin="0,0,6,4"
                                ToolTip="Read the report aloud — proofread by ear before sending">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ButtonIconStyle}" Text="&#xE767;" FontSize="11"/>
                                <TextBlock Text="Read Aloud"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding StopReadingCommand}" Content="Stop" Style="{StaticResource ModernButtonStyle}" Height="26" Padding="8,0" FontSize="11" Margin="0,0,6,4" AutomationProperties.Name="Stop reading aloud"/>
                        <Button Command="{Binding RestoreAiDraftCommand}" Style="{StaticResource ModernButtonStyle}" Height="26" Padding="8,0" FontSize="11" Margin="0,0,0,4"
                                ToolTip="Undo all your edits and go back to the AI's original draft">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ButtonIconStyle}" Text="&#xE7A7;" FontSize="11"/>
                                <TextBlock Text="Restore AI Draft"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Text="{Binding GeneratedReportOutput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="0" TextWrapping="Wrap" AcceptsReturn="True" FontSize="14" Padding="15">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Setter Property="Grid.ColumnSpan" Value="1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCompareRightVisible}" Value="False">
                                        <Setter Property="Grid.ColumnSpan" Value="2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <TextBox Text="{Binding CompareOutputRight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Background="{DynamicResource ThemePreviewBg}" Grid.Column="1" Margin="10,0,0,0" TextWrapping="Wrap" AcceptsReturn="True" FontSize="14" Padding="15" Visibility="{Binding IsCompareRightVisible, Converter={StaticResource BoolToVis}}"/>
                </Grid>

                <WrapPanel Grid.Row="2" HorizontalAlignment="Right">
                    <Button Command="{Binding UpdateHistoryEditCommand}" AutomationProperties.Name="Save Edits" Style="{StaticResource ModernButtonStyle}" Background="{DynamicResource ThemeSuccessBg}" Foreground="{DynamicResource ThemeSuccessText}" Margin="5,5,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ButtonIconStyle}" Text="&#xE74E;"/>
                            <TextBlock Text="Save Edits"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding CopyReportCommand}" AutomationProperties.Name="Copy Text" Style="{StaticResource ModernButtonStyle}" Margin="5,5,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ButtonIconStyle}" Text="&#xE8C8;"/>
                            <TextBlock Text="Copy Text"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding EmailReportCommand}" AutomationProperties.Name="Email Parent" Style="{StaticResource ModernButtonStyle}" Background="{DynamicResource ThemeWarningBg}" Foreground="{DynamicResource ThemeWarningText}" Margin="5,5,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ButtonIconStyle}" Text="&#xE715;"/>
                            <TextBlock Text="Email Parent"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding SavePdfCommand}" Content="Export PDF" Style="{StaticResource ModernPrimaryButtonStyle}" Background="{DynamicResource ThemeDangerStrongBg}" Margin="5,5,0,0" />
                    <Button Command="{Binding SaveWordCommand}" Content="Export Word (.docx)" Style="{StaticResource ModernPrimaryButtonStyle}" Background="{DynamicResource ThemeAccentBlueBg}" Margin="5,5,0,0" />
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource ModernCardStyle}" x:Name="Card3"
                Visibility="{Binding SettingsVM.IsSimpleMode, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1.5*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="HISTORY LOG" FontWeight="Bold" FontSize="16" Foreground="{Binding SettingsVM.NavBarBackground}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <TextBox Grid.Column="1" Text="{Binding HistorySearchText, UpdateSourceTrigger=PropertyChanged}" Height="30" Padding="8,4" FontSize="13" ToolTip="Search by student name or keywords..." Margin="0,0,10,0"/>
                        <Button Command="{Binding ShowAllHistoryCommand}" Grid.Column="2" Content="Clear Filter" Style="{StaticResource ModernButtonStyle}" Height="30" Padding="10,0" />
                    </Grid>
                    <TextBlock Text="past reports." FontSize="12" Margin="0,4,0,10" Foreground="{DynamicResource ThemeMutedText}"/>
                </StackPanel>

                <ListBox ItemsSource="{Binding SessionHistory}" 
                         SelectedItem="{Binding SelectedHistoryItem}" 
                         DisplayMemberPath="DisplayText" 
                         Grid.Row="1" FontSize="14" Margin="0,0,0,15">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu>
                                        <MenuItem Header="Delete Record" 
                                                  Command="{Binding PlacementTarget.Tag.DeleteHistoryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <Grid Grid.Row="2" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="HISTORY SNAPSHOT" FontWeight="Bold" FontSize="11" Foreground="{DynamicResource ThemeMutedText}" VerticalAlignment="Center"/>
                    <Button Command="{Binding CompareHistoryCommand}" Grid.Column="1" Content="Compare w/ Editor" Style="{StaticResource ModernButtonStyle}" Height="25" Padding="10,0" />
                </Grid>

                <TextBox Text="{Binding SelectedHistoryItem.GeneratedReport, Mode=OneWay}" Background="{DynamicResource ThemePreviewBg}" Grid.Row="3" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True" FontSize="13" Padding="15"/>
            </Grid>
        </Border>

        <!-- Persistent status bar: success/failure messages stay visible app-wide instead of
             relying solely on the small status line inside the preview card -->
        <Border Grid.Row="2" Grid.ColumnSpan="3" Background="{DynamicResource ThemeCardBg}" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,1,0,0" Padding="15,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="{DynamicResource ThemeText}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding AboutInfo}" FontSize="11" Foreground="{DynamicResource ThemeMutedText}" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border x:Name="overlayWelcome" Visibility="{Binding IsWelcomeOverlayVisible, Converter={StaticResource BoolToVis}}" Grid.Row="0" Grid.RowSpan="3" Grid.ColumnSpan="3" Background="#F2000000" Panel.ZIndex="100">
            <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="12" Width="720" Height="580" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="35">
                <StackPanel>
                    <TextBlock Text="Welcome to AI Student Report Generator" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource ThemeText}" TextAlignment="Center" Margin="0,0,0,10"/>

                    <StackPanel Visibility="{Binding IsProfileSetupVisible, Converter={StaticResource BoolToVis}}" Margin="0,5,0,15">
                        <TextBlock Text="Configure teacher signature contexts details here." FontSize="14" Foreground="{DynamicResource ThemeMutedText}" TextAlignment="Center" Margin="0,0,0,15"/>
                        <Grid Width="380" HorizontalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Teacher Signature (e.g. Mr. Smith):" FontWeight="SemiBold" Margin="0,0,0,5" Grid.Row="0"/>
                            <TextBox Text="{Binding SettingsVM.SettingsTeacherName, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="8" FontSize="14" Margin="0,0,0,12" Grid.Row="1"/>
                            <TextBlock Text="School Institution Name:" FontWeight="SemiBold" Margin="0,0,0,5" Grid.Row="2"/>
                            <TextBox Text="{Binding SettingsVM.SettingsSchoolName, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="8" FontSize="14" Grid.Row="3"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Visibility="{Binding IsWelcomeBackVisible, Converter={StaticResource BoolToVis}}" Margin="0,10,0,15">
                        <TextBlock Text="System Active &amp; Ready!" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource ThemeSuccessAccent}" TextAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock Text="Everything is set up and ready to go" FontSize="14" Foreground="{DynamicResource ThemeMutedText}" TextAlignment="Center" Margin="0,0,0,10"/>
                        <Button Command="{Binding EditWelcomeProfileCommand}" Content="Edit Administrative Profile Properties" Style="{StaticResource ModernButtonStyle}" Background="Transparent" Foreground="{Binding SettingsVM.NavBarBackground}" Height="25" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Grid Margin="0,5,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="5">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                                <TextBlock Style="{StaticResource ButtonIconStyle}" Text="&#xE713;" FontSize="15" Foreground="{DynamicResource ThemeInfoAccent}"/>
                                <TextBlock Text="Configuration" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource ThemeInfoAccent}"/>
                            </StackPanel>
                            <TextBlock Text="Enter your AI provider key in settings to get started." Foreground="{DynamicResource ThemeText}" TextWrapping="Wrap" TextAlignment="Center" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                                <TextBlock Style="{StaticResource ButtonIconStyle}" Text="&#xE70F;" FontSize="15" Foreground="{DynamicResource ThemeSuccessAccent}"/>
                                <TextBlock Text="Aggregation" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource ThemeSuccessAccent}"/>
                            </StackPanel>
                            <TextBlock Text="Add your students and subjects to your student list." Foreground="{DynamicResource ThemeText}" TextWrapping="Wrap" TextAlignment="Center" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="5">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                                <TextBlock Style="{StaticResource ButtonIconStyle}" Text="&#xE945;" FontSize="15" Foreground="{DynamicResource ThemeWarningAccent}"/>
                                <TextBlock Text="Optimization" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource ThemeWarningAccent}"/>
                            </StackPanel>
                            <TextBlock Text="Generate reports for your whole class at once" Foreground="{DynamicResource ThemeText}" TextWrapping="Wrap" TextAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                    <Border Background="{DynamicResource ThemeWarningBg}" CornerRadius="8" Padding="12" Margin="0,0,0,20">
                        <TextBlock Text="Your student data is sent securely to your chosen AI provider only to generate the report. It is never stored on external servers or used to train AI models. All local files are encrypted and stored only on this computer." TextWrapping="Wrap" Foreground="{DynamicResource ThemeWarningText}" FontWeight="SemiBold" TextAlignment="Center" FontSize="11"/>
                    </Border>
                    <Grid>
                        <Button Command="{Binding EnterAppCommand}" Content="Get Started" Height="45" Width="360" FontSize="15" Style="{StaticResource ModernPrimaryButtonStyle}" HorizontalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>