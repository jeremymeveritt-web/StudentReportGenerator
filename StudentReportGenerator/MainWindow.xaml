<Window x:Class="StudentReportGenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:StudentReportGenerator.Services"
        xmlns:converters="clr-namespace:StudentReportGenerator.Converters"
        Title="AI Student Report Generator" Height="768" Width="1366"
        Icon="/Assets/app.ico"
        MinWidth="1100" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        FontFamily="{DynamicResource AppFontFamily}"
        FontSize="{DynamicResource AppFontSize}"
        Background="{DynamicResource ThemeAppBg}" Foreground="{DynamicResource ThemeText}">

    <Window.Resources>
        <converters:InverseBoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:BoolToGridLengthConverter x:Key="BoolToColWidth" />

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource ThemeInputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{DynamicResource ThemeInputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource ThemeCardBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
        </Style>

        <!-- Vector icon glyphs (Segoe Fluent on Win11, MDL2 fallback on Win10) replace raw emoji
             for a consistent, high-DPI-safe look across Windows versions and locales -->
        <Style x:Key="ButtonIconStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>

        <Style x:Key="ModernCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeCardBg}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeMetricCardBg}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <Style TargetType="Button" x:Key="ModernButtonStyle">
            <Setter Property="Background" Value="{DynamicResource ThemeButtonBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="15,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ThemeButtonHoverBg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource ThemePrimaryBtnBg}"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ThemePrimaryBtnHoverBg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainLayoutGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.3*"/>
            <ColumnDefinition Width="1.6*"/>
            <!-- Simple mode hides the history column so a teacher's first sessions face a calmer, two-panel layout -->
            <ColumnDefinition Width="{Binding SettingsVM.IsSimpleMode, Converter={StaticResource BoolToColWidth}, ConverterParameter=1.0}"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <Border x:Name="TopNavBar" Grid.Row="0" Grid.ColumnSpan="3" Background="{Binding SettingsVM.NavBarBackground}" Padding="20,0,20,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="{Binding SettingsVM.SchoolLogoImage}" Height="40" Margin="0,0,15,0" 
                           Visibility="{Binding SettingsVM.IsLogoVisible, Converter={StaticResource BoolToVis}}" Stretch="Uniform"/>
                    <TextBlock Text="{Binding SettingsVM.MainAppTitle}" FontWeight="Bold" FontSize="18" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text=" - Teacher Suite" FontSize="12" Foreground="#FFCCCCCC" Margin="5,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource ModernCardStyle}" x:Name="Card1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock x:Name="lblActiveModule" Text="MENU SELECT:" FontWeight="Bold" Foreground="{Binding SettingsVM.NavBarBackground}" Margin="0,0,0,5" FontSize="11"/>
                    <ComboBox SelectedIndex="{Binding SelectedNavigationIndex}" Height="40" FontSize="14" FontWeight="SemiBold" Padding="10,8" AutomationProperties.Name="Menu Select">
                        <ComboBoxItem AutomationProperties.Name="Single Report Generator">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ButtonIconStyle}" Text="&#xE70F;"/>
                                <TextBlock Text="Single Report Generator"/>
                            </StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem AutomationProperties.Name="Whole-Class Reports">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ButtonIconStyle}" Text="&#xE8F1;"/>
                                <TextBlock Text="Whole-Class Reports"/>
                            </StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem AutomationProperties.Name="Compare AI Writing Styles">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ButtonIconStyle}" Text="&#xE8AB;"/>
                                <TextBlock Text="Compare AI Writing Styles"/>
                            </StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem AutomationProperties.Name="My Profile and School Settings">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ButtonIconStyle}" Text="&#xE77B;"/>
                                <TextBlock Text="My Profile &amp; School Settings"/>
                            </StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem AutomationProperties.Name="AI Provider and API Keys">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ButtonIconStyle}" Text="&#xE8D7;"/>
                                <TextBlock Text="AI Provider &amp; API Keys"/>
                            </StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem AutomationProperties.Name="Usage Statistics">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ButtonIconStyle}" Text="&#xE9D9;"/>
                                <TextBlock Text="Usage Statistics"/>
                            </StackPanel>
                        </ComboBoxItem>
                    </ComboBox>
                    <Rectangle Height="1" Fill="{DynamicResource ThemeBorder}" Margin="0,15,0,0"/>
                </StackPanel>

                <Grid Grid.Row="1">

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,0,0">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedNavigationIndex}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>
                        <StackPanel Margin="0,0,10,10">
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Student Name:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBlock Grid.Column="1" Text="Class/Group:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Text="{Binding SelectedStudentName, UpdateSourceTrigger=PropertyChanged}" ItemsSource="{Binding StudentNames}" IsEditable="True" Height="35" Padding="5" Margin="0,0,8,0" FontSize="13" />
                                <TextBox Text="{Binding StudentClass, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" Height="35" Padding="8" FontSize="13" Margin="0,0,8,0"/>
                                <Button Command="{Binding SaveStudentCommand}" Grid.Column="2" Content="Save" Style="{StaticResource ModernButtonStyle}" Width="Auto" Padding="12,0" Height="35" Margin="0,0,5,0"/>
                                <Button Command="{Binding DeleteStudentCommand}" Grid.Column="3" Content="Delete" Style="{StaticResource ModernButtonStyle}" Background="{DynamicResource ThemeDangerBg}" Foreground="{DynamicResource ThemeDangerText}" Width="Auto" Padding="12,0" Height="35"/>
                            </Grid>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="1.5*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Target Grade:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding TargetGrade, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="8" FontSize="13"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Pronouns:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <ComboBox Text="{Binding SelectedPronouns}" IsEditable="True" Height="35" Padding="5" FontSize="13">
                                        <ComboBoxItem Content="He/Him"/>
                                        <ComboBoxItem Content="She/Her"/>
                                        <ComboBoxItem Content="They/Them"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Support Needs:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding SupportNeeds, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="8" FontSize="13"/>
                                </StackPanel>
                                <StackPanel Grid.Column="6">
                                    <TextBlock Text="Parent Email:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding ParentEmail, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="8" FontSize="13"/>
                                </StackPanel>
                            </Grid>

                            <WrapPanel Margin="0,0,0,20">
                                <Button Command="{Binding ImportRosterCommand}" AutomationProperties.Name="Import Roster" Style="{StaticResource ModernButtonStyle}" Background="{DynamicResource ThemeInfoBg}" Foreground="{DynamicResource ThemeInfoText}" Height="30" Margin="0,0,8,5">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource ButtonIconStyle}" Text="&#xE8B5;"/>
                                        <TextBlock Text="Import Roster"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding ViewStudentHistoryCommand}" AutomationProperties.Name="View History" Style="{StaticResource ModernButtonStyle}" Background="{DynamicResource ThemeWarningBg}" Foreground="{DynamicResource ThemeWarningText}" Height="30" Margin="0,0,0,5">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource ButtonIconStyle}" Text="&#xE81C;"/>
                                        <TextBlock Text="View History"/>
                                    </StackPanel>
                                </Button>
                            </WrapPanel>

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Vertical" Margin="0,0,0,15">
                                    <TextBlock Text="TARGET WORD COUNT:" FontSize="11" FontWeight="Bold" Foreground="{Binding SettingsVM.NavBarBackground}" Margin="0,0,0,5"/>
                                    <ComboBox SelectedValue="{Binding TargetWordCount, Mode=TwoWay}" SelectedValuePath="Tag" Height="35" Padding="5" FontSize="13">
                                        <ComboBoxItem Content="~300 Words" Tag="300"/>
                                        <ComboBoxItem Content="~500 Words" Tag="500"/>
                                        <ComboBoxItem Content="~800 Words" Tag="800"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Tone Template:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="115"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox ItemsSource="{Binding CustomFrameworks}" SelectedItem="{Binding SelectedFramework}" DisplayMemberPath="Name" Height="35" Padding="5" FontSize="13" Margin="0,0,5,0"/>
                                        <Button Command="{Binding PreviewToneCommand}" Grid.Column="1" Content="Preview Tone" Style="{StaticResource ModernButtonStyle}" Width="110" Height="35" />
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <Border Background="{DynamicResource ThemePreviewBg}" CornerRadius="8" Padding="15" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="REPORT ATTRIBUTES" FontWeight="Bold" Foreground="{Binding SettingsVM.NavBarBackground}" Margin="0,0,0,10"/>
                                    <TextBlock Text="Curriculum Topic:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Text="{Binding SelectedCurriculumTopic, UpdateSourceTrigger=PropertyChanged}" ItemsSource="{Binding CurriculumTopics}" IsEditable="True" Height="35" Padding="5" Margin="0,0,8,0" FontSize="13"/>
                                        <Button Command="{Binding SaveCurriculumCommand}" Grid.Column="1" Content="Save" Style="{StaticResource ModernButtonStyle}" Width="Auto" Padding="15,0" Height="35" Margin="0,0,5,0"/>
                                        <Button Command="{Binding DeleteCurriculumCommand}" Grid.Column="2" Content="Delete" Style="{StaticResource ModernButtonStyle}" Background="{DynamicResource ThemeDangerBg}" Foreground="{DynamicResource ThemeDangerText}" Width="Auto" Padding="12,0" Height="35" />
                                    </Grid>

                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                            <TextBlock Text="Attendance:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                            <RadioButton IsChecked="{Binding IsTimekeepingPerfect}" GroupName="Time" Content="Perfect 100%" Margin="0,0,0,6"/>
                                            <RadioButton IsChecked="{Binding IsTimekeepingGood}" GroupName="Time" Content="Good/Acceptable" Margin="0,0,0,6"/>
                                            <RadioButton IsChecked="{Binding IsTimekeepingPoor}" GroupName="Time" Content="Absence Issues" Margin="0,0,0,6"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Contributions:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                            <RadioButton IsChecked="{Binding IsContributionEnthusiastic}" GroupName="Contrib" Content="Enthusiastic" Margin="0,0,0,6"/>
                                            <RadioButton IsChecked="{Binding IsContributionOccasional}" GroupName="Contrib" Content="Occasional" Margin="0,0,0,6"/>
                                            <RadioButton IsChecked="{Binding IsContributionRare}" GroupName="Contrib" Content="Rare, high quality" Margin="0,0,0,6"/>
                                            <RadioButton IsChecked="{Binding IsContributionNever}" GroupName="Contrib" Content="Passive observer" Margin="0,0,0,6"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,10,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Teacher Observations (Optional):" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Command="{Binding DictateCommand}" AutomationProperties.Name="Dictate observations"
                                                Style="{StaticResource ModernButtonStyle}" Height="26" Padding="8,0"
                                                ToolTip="Dictate your observations using your microphone (processed entirely on this computer)">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Style="{StaticResource ButtonIconStyle}" Text="&#xE720;"/>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Dictate"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDictating}" Value="True">
                                                                    <Setter Property="Text" Value="Stop"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                    <Grid Height="80">
                                        <TextBox Text="{Binding CustomNotes, UpdateSourceTrigger=PropertyChanged}" SpellCheck.IsEnabled="True" TextWrapping="Wrap" AcceptsReturn="True" Padding="8" FontSize="13"/>
                                    </Grid>

                                    <Expander Header="Comment Bank — reusable phrases" Margin="0,10,0,0" FontSize="12">
                                        <StackPanel Margin="0,8,0,0">
                                            <TextBox Text="{Binding CommentFilterText, UpdateSourceTrigger=PropertyChanged}" Height="28" Padding="6,4" FontSize="12" ToolTip="Type to filter your saved phrases..."/>
                                            <ListBox ItemsSource="{Binding VisibleCommentBank}" MaxHeight="110" FontSize="12" Margin="0,6,0,6" BorderThickness="1">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                            <Button Grid.Column="1" Content="Insert" FontSize="10" Padding="6,1" Margin="6,0,0,0"
                                                                    Command="{Binding DataContext.InsertPhraseCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                    CommandParameter="{Binding}"/>
                                                            <Button Grid.Column="2" Content="✕" FontSize="10" Padding="5,1" Margin="4,0,0,0" AutomationProperties.Name="Delete phrase"
                                                                    Command="{Binding DataContext.DeletePhraseCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                    CommandParameter="{Binding}"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Text="{Binding NewPhraseText, UpdateSourceTrigger=PropertyChanged}" Height="28" Padding="6,4" FontSize="12" Margin="0,0,6,0" ToolTip="Add a new phrase to your bank..."/>
                                                <Button Grid.Column="1" Command="{Binding AddPhraseCommand}" Content="Save Phrase" Style="{StaticResource ModernButtonStyle}" Height="28" Padding="10,0" FontSize="11"/>
                                            </Grid>
                                        </StackPanel>
                                    </Expander>

                                    <Expander Header="Previous report for this student" Margin="0,6,0,0" FontSize="12"
                                              Visibility="{Binding HasLastTermReport, Converter={StaticResource BoolToVis}}">
                                        <TextBox Text="{Binding LastTermReportPreview, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" MaxHeight="140"
                                                 VerticalScrollBarVisibility="Auto" FontSize="12" Padding="8" Margin="0,8,0,0"
                                                 Background="{DynamicResource ThemePreviewBg}"/>
                                    </Expander>
                                </StackPanel>
                            </Border>
                            <Button Command="{Binding GenerateSingleCommand}" Content="Generate Report" Height="45" FontSize="14" Style="{StaticResource ModernPrimaryButtonStyle}" Margin="0,5,0,0"/>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Margin="0,0,10,10">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedNavigationIndex}" Value="1">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="WHOLE-CLASS REPORTS" FontWeight="Bold" Foreground="{Binding SettingsVM.NavBarBackground}" Margin="0,10,0,5"/>
                        <TextBlock Text="Upload class list CSV files (Format: Name | Notes) to generate multi-student reports." Foreground="{DynamicResource ThemeMutedText}" TextWrapping="Wrap" FontSize="13" Margin="0,0,0,20"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="TARGET WORD COUNT:" FontSize="11" FontWeight="Bold" Foreground="{Binding SettingsVM.NavBarBackground}" Margin="0,0,0,5"/>
                                <ComboBox SelectedValue="{Binding TargetWordCount, Mode=TwoWay}" SelectedValuePath="Tag" Height="35" Padding="5" FontSize="13">
                                    <ComboBoxItem Content="~300 Words" Tag="300"/>
                                    <ComboBoxItem Content="~500 Words" Tag="500"/>
                                    <ComboBoxItem Content="~800 Words" Tag="800"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Vertical">
                                <TextBlock Text="TONE TEMPLATE:" FontSize="11" FontWeight="Bold" Foreground="{Binding SettingsVM.NavBarBackground}" Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding CustomFrameworks}" SelectedItem="{Binding SelectedFramework}" DisplayMemberPath="Name" Height="35" Padding="5" FontSize="13"/>
                            </StackPanel>
                        </Grid>

                        <!-- Rapid-fire entry: one student at a time, Enter/Next to advance — no
                             hand-formatting of pipe-delimited lines needed -->
                        <Expander Header="⚡ Rapid entry (one student at a time)" FontSize="12" Margin="0,0,0,10">
                            <Border Background="{DynamicResource ThemePreviewBg}" CornerRadius="6" Padding="10" Margin="0,6,0,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding RapidProgressDisplay}" FontSize="11" Foreground="{DynamicResource ThemeMutedText}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding RapidCurrentName}" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding RapidNotes, UpdateSourceTrigger=PropertyChanged}" Height="50" TextWrapping="Wrap" AcceptsReturn="False" Padding="6" FontSize="12" Margin="0,0,0,6">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Return" Command="{Binding RapidNextCommand}"/>
                                        </TextBox.InputBindings>
                                    </TextBox>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Command="{Binding RapidNextCommand}" Content="Add &amp; Next (Enter)" Style="{StaticResource ModernPrimaryButtonStyle}" Height="28" Padding="10,0" FontSize="11" Margin="0,0,8,0"/>
                                        <Button Command="{Binding RapidSkipCommand}" Content="Skip Student" Style="{StaticResource ModernButtonStyle}" Height="28" Padding="10,0" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Expander>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Batch Roster Data:" FontWeight="SemiBold" VerticalAlignment="Bottom"/>

                            <Button Command="{Binding ClearBatchCommand}" Grid.Column="1" AutomationProperties.Name="Clear Batch" Style="{StaticResource ModernButtonStyle}" Background="{DynamicResource ThemeDangerBg}" Foreground="{DynamicResource ThemeDangerText}" Width="105" Height="30" Margin="0,0,10,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource ButtonIconStyle}" Text="&#xE74D;"/>
                                    <TextBlock Text="Clear Batch"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding ImportBatchCsvCommand}" Grid.Column="2" Content="Upload CSV List" Style="{StaticResource ModernButtonStyle}" Background="{DynamicResource ThemeInfoBg}" Foreground="{DynamicResource ThemeInfoText}" Width="130" Height="30" />
                        </Grid>
                        <Grid Height="280">
                            <TextBox Text="{Binding BatchDataInput, UpdateSourceTrigger=PropertyChanged}" SpellCheck.IsEnabled="True" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,15" Padding="10" VerticalScrollBarVisibility="Auto" FontSize="13"/>
                        </Grid>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Button Command="{Binding GenerateBatchCommand}" Content="Process Entire Class" Height="45" Style="{StaticResource ModernPrimaryButtonStyle}" Visibility="{Binding IsBatchModeActive, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                                <Button Command="{Binding CancelBatchCommand}" AutomationProperties.Name="Stop Generation" Height="45" Style="{StaticResource ModernPrimaryButtonStyle}" Background="{DynamicResource ThemeDangerStrongBg}" Visibility="{Binding IsBatchModeActive, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource ButtonIconStyle}" Text="&#xE71A;"/>
                                        <TextBlock Text="Stop Generation"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
