<Window x:Class="StudentReportGenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:StudentReportGenerator.Services"
        xmlns:converters="clr-namespace:StudentReportGenerator.Converters"
        Title="AI Student Report Generator" Height="768" Width="1366"
        MinWidth="1100" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ThemeAppBg}" Foreground="{DynamicResource ThemeText}">

    <Window.Resources>
        <converters:InverseBoolToVisibilityConverter x:Key="BoolToVis" />

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource ThemeInputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{DynamicResource ThemeInputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource ThemeCardBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
        </Style>

        <Style x:Key="ModernCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeCardBg}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFF5F5F5"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <Style TargetType="Button" x:Key="ModernButtonStyle">
            <Setter Property="Background" Value="#FFEEEEEE"/>
            <Setter Property="Foreground" Value="#FF333333"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="15,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFDDDDDD"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#FF4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF43A047"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainLayoutGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.3*"/>
            <ColumnDefinition Width="1.6*"/>
            <ColumnDefinition Width="1.0*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border x:Name="TopNavBar" Grid.Row="0" Grid.ColumnSpan="3" Background="{Binding SettingsVM.NavBarBackground}" Padding="20,0,20,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="{Binding SettingsVM.SchoolLogoImage}" Height="40" Margin="0,0,15,0" 
                           Visibility="{Binding SettingsVM.IsLogoVisible, Converter={StaticResource BoolToVis}}" Stretch="Uniform"/>
                    <TextBlock Text="{Binding SettingsVM.MainAppTitle}" FontWeight="Bold" FontSize="18" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text=" - Teacher Suite" FontSize="12" Foreground="#FFCCCCCC" Margin="5,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource ModernCardStyle}" x:Name="Card1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock x:Name="lblActiveModule" Text="MENU SELECT:" FontWeight="Bold" Foreground="{Binding SettingsVM.NavBarBackground}" Margin="0,0,0,5" FontSize="11"/>
                    <ComboBox SelectedIndex="{Binding SelectedNavigationIndex}" Height="40" FontSize="14" FontWeight="SemiBold" Padding="10,8">
                        <ComboBoxItem Content="📝 Single Report Generator"/>
                        <ComboBoxItem Content="📚 Whole-Class Reports"/>
                        <ComboBoxItem Content="⚖️ Compare AI Writing Styles"/>
                        <ComboBoxItem Content="👤 My Profile &amp; School Settings"/>
                        <ComboBoxItem Content="🧠 AI Provider &amp; API Keys"/>
                        <ComboBoxItem Content="📊 Usage Statistics"/>
                    </ComboBox>
                    <Rectangle Height="1" Fill="{DynamicResource ThemeBorder}" Margin="0,15,0,0"/>
                </StackPanel>

                <Grid Grid.Row="1">

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,0,0">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedNavigationIndex}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>
                        <StackPanel Margin="0,0,10,10">
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Student Name:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBlock Grid.Column="1" Text="Class/Group:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Text="{Binding SelectedStudentName, UpdateSourceTrigger=PropertyChanged}" ItemsSource="{Binding StudentNames}" IsEditable="True" Height="35" Padding="5" Margin="0,0,8,0" FontSize="13" />
                                <TextBox Text="{Binding StudentClass, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" Height="35" Padding="8" FontSize="13" Margin="0,0,8,0"/>
                                <Button Command="{Binding SaveStudentCommand}" Grid.Column="2" Content="Save" Style="{StaticResource ModernButtonStyle}" Width="Auto" Padding="12,0" Height="35" Margin="0,0,5,0"/>
                                <Button Command="{Binding DeleteStudentCommand}" Grid.Column="3" Content="Delete" Style="{StaticResource ModernButtonStyle}" Background="#FFFFEBEE" Foreground="#FFD32F2F" Width="Auto" Padding="12,0" Height="35"/>
                            </Grid>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="1.5*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Target Grade:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding TargetGrade, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="8" FontSize="13"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Pronouns:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <ComboBox Text="{Binding SelectedPronouns}" IsEditable="True" Height="35" Padding="5" FontSize="13">
                                        <ComboBoxItem Content="He/Him"/>
                                        <ComboBoxItem Content="She/Her"/>
                                        <ComboBoxItem Content="They/Them"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Support Needs:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding SupportNeeds, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="8" FontSize="13"/>
                                </StackPanel>
                                <StackPanel Grid.Column="6">
                                    <TextBlock Text="Parent Email:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding ParentEmail, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="8" FontSize="13"/>
                                </StackPanel>
                            </Grid>

                            <WrapPanel Margin="0,0,0,20">
                                <Button Command="{Binding ImportRosterCommand}" Content="📁 Import Roster" Style="{StaticResource ModernButtonStyle}" Background="#FFE0F7FA" Foreground="#FF0097A7" Height="30" Margin="0,0,8,5" />
                                <Button Command="{Binding ViewStudentHistoryCommand}" Content="🕒 View History" Style="{StaticResource ModernButtonStyle}" Background="#FFF3E0" Foreground="#FFE65100" Height="30" Margin="0,0,0,5" />
                            </WrapPanel>

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Vertical" Margin="0,0,0,15">
                                    <TextBlock Text="TARGET WORD COUNT:" FontSize="11" FontWeight="Bold" Foreground="{Binding SettingsVM.NavBarBackground}" Margin="0,0,0,5"/>
                                    <ComboBox SelectedValue="{Binding TargetWordCount, Mode=TwoWay}" SelectedValuePath="Tag" Height="35" Padding="5" FontSize="13">
                                        <ComboBoxItem Content="~300 Words" Tag="300"/>
                                        <ComboBoxItem Content="~500 Words" Tag="500"/>
                                        <ComboBoxItem Content="~800 Words" Tag="800"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Tone Template:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="115"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox ItemsSource="{Binding CustomFrameworks}" SelectedItem="{Binding SelectedFramework}" DisplayMemberPath="Name" Height="35" Padding="5" FontSize="13" Margin="0,0,5,0"/>
                                        <Button Command="{Binding PreviewToneCommand}" Grid.Column="1" Content="Preview Tone" Style="{StaticResource ModernButtonStyle}" Width="110" Height="35" />
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <Border Background="{DynamicResource ThemePreviewBg}" CornerRadius="8" Padding="15" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="REPORT ATTRIBUTES" FontWeight="Bold" Foreground="{Binding SettingsVM.NavBarBackground}" Margin="0,0,0,10"/>
                                    <TextBlock Text="Curriculum Topic:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Text="{Binding SelectedCurriculumTopic, UpdateSourceTrigger=PropertyChanged}" ItemsSource="{Binding CurriculumTopics}" IsEditable="True" Height="35" Padding="5" Margin="0,0,8,0" FontSize="13"/>
                                        <Button Command="{Binding SaveCurriculumCommand}" Grid.Column="1" Content="Save" Style="{StaticResource ModernButtonStyle}" Width="Auto" Padding="15,0" Height="35" Margin="0,0,5,0"/>
                                        <Button Command="{Binding DeleteCurriculumCommand}" Grid.Column="2" Content="Delete" Style="{StaticResource ModernButtonStyle}" Background="#FFFFEBEE" Foreground="#FFD32F2F" Width="Auto" Padding="12,0" Height="35" />
                                    </Grid>

                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                            <TextBlock Text="Attendance:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                            <RadioButton IsChecked="{Binding IsTimekeepingPerfect}" GroupName="Time" Content="Perfect 100%" Margin="0,0,0,6"/>
                                            <RadioButton IsChecked="{Binding IsTimekeepingGood}" GroupName="Time" Content="Good/Acceptable" Margin="0,0,0,6"/>
                                            <RadioButton IsChecked="{Binding IsTimekeepingPoor}" GroupName="Time" Content="Absence Issues" Margin="0,0,0,6"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Contributions:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                            <RadioButton IsChecked="{Binding IsContributionEnthusiastic}" GroupName="Contrib" Content="Enthusiastic" Margin="0,0,0,6"/>
                                            <RadioButton IsChecked="{Binding IsContributionOccasional}" GroupName="Contrib" Content="Occasional" Margin="0,0,0,6"/>
                                            <RadioButton IsChecked="{Binding IsContributionRare}" GroupName="Contrib" Content="Rare, high quality" Margin="0,0,0,6"/>
                                            <RadioButton IsChecked="{Binding IsContributionNever}" GroupName="Contrib" Content="Passive observer" Margin="0,0,0,6"/>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="Teacher Observations (Optional):" FontWeight="SemiBold" Margin="0,10,0,5"/>
                                    <Grid Height="80">
                                        <TextBox Text="{Binding CustomNotes, UpdateSourceTrigger=PropertyChanged}" SpellCheck.IsEnabled="True" TextWrapping="Wrap" AcceptsReturn="True" Padding="8" FontSize="13"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Button Command="{Binding GenerateSingleCommand}" Content="Generate Report" Height="45" FontSize="14" Style="{StaticResource ModernPrimaryButtonStyle}" Margin="0,5,0,0"/>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Margin="0,0,10,10">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedNavigationIndex}" Value="1">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="WHOLE-CLASS REPORTS" FontWeight="Bold" Foreground="{Binding SettingsVM.NavBarBackground}" Margin="0,10,0,5"/>
                        <TextBlock Text="Upload class list CSV files (Format: Name | Notes) to generate multi-student reports." Foreground="{DynamicResource ThemeMutedText}" TextWrapping="Wrap" FontSize="13" Margin="0,0,0,20"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="TARGET WORD COUNT:" FontSize="11" FontWeight="Bold" Foreground="{Binding SettingsVM.NavBarBackground}" Margin="0,0,0,5"/>
                                <ComboBox SelectedValue="{Binding TargetWordCount, Mode=TwoWay}" SelectedValuePath="Tag" Height="35" Padding="5" FontSize="13">
                                    <ComboBoxItem Content="~300 Words" Tag="300"/>
                                    <ComboBoxItem Content="~500 Words" Tag="500"/>
                                    <ComboBoxItem Content="~800 Words" Tag="800"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Vertical">
                                <TextBlock Text="TONE TEMPLATE:" FontSize="11" FontWeight="Bold" Foreground="{Binding SettingsVM.NavBarBackground}" Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding CustomFrameworks}" SelectedItem="{Binding SelectedFramework}" DisplayMemberPath="Name" Height="35" Padding="5" FontSize="13"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Batch Roster Data:" FontWeight="SemiBold" VerticalAlignment="Bottom"/>

                            <Button Command="{Binding ClearBatchCommand}" Grid.Column="1" Content="🗑️ Clear Batch" Style="{StaticResource ModernButtonStyle}" Background="#FFFFEBEE" Foreground="#FFD32F2F" Width="105" Height="30" Margin="0,0,10,0"/>

                            <Button Command="{Binding ImportBatchCsvCommand}" Grid.Column="2" Content="Upload CSV List" Style="{StaticResource ModernButtonStyle}" Background="#FFE0F7FA" Foreground="#FF0097A7" Width="130" Height="30" />
                        </Grid>
                        <Grid Height="280">
                            <TextBox Text="{Binding BatchDataInput, UpdateSourceTrigger=PropertyChanged}" SpellCheck.IsEnabled="True" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,15" Padding="10" VerticalScrollBarVisibility="Auto" FontSize="13"/>
                        </Grid>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Button Command="{Binding GenerateBatchCommand}" Content="Process Entire Class" Height="45" Style="{StaticResource ModernPrimaryButtonStyle}" Visibility="{Binding IsBatchModeActive, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                                <Button Command="{Binding CancelBatchCommand}" Content="🛑 Stop Generation" Height="45" Style="{StaticResource ModernPrimaryButtonStyle}" Background="#FFF44336" Visibility="{Binding IsBatchModeActive, Converter={StaticResource BoolToVis}}"/>
                            </Grid>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Command="{Binding CopyBatchCommand}" Content="📋 Copy All Text" Height="45" Style="{StaticResource ModernButtonStyle}" Width="130" Margin="0,0,10,0" />
                                <Button Command="{Binding ExportBatchWordCommand}" Content="Export Batch (.docx)" Height="45" Style="{StaticResource ModernPrimaryButtonStyle}" Background="#FF1976D2" Width="140" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <StackPanel Margin="0,0,10,10">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedNavigationIndex}" Value="2">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="COMPARE AI WRITING STYLES" FontWeight="Bold" Foreground="{Binding SettingsVM.NavBarBackground}" Margin="0,10,0,5"/>
                        <TextBlock Text="Compare how two different AI models write the same report." Foreground="{DynamicResource ThemeMutedText}" TextWrapping="Wrap" FontSize="13" Margin="0,0,0,20"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="TARGET WORD COUNT:" FontSize="11" FontWeight="Bold" Foreground="{Binding SettingsVM.NavBarBackground}" Margin="0,0,0,5"/>
                                <ComboBox SelectedValue="{Binding TargetWordCount, Mode=TwoWay}" SelectedValuePath="Tag" Height="35" Padding="5" FontSize="13">
                                    <ComboBoxItem Content="~300 Words" Tag="300"/>
                                    <ComboBoxItem Content="~500 Words" Tag="500"/>
                                    <ComboBoxItem Content="~800 Words" Tag="800"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Vertical">
                                <TextBlock Text="TONE TEMPLATE:" FontSize="11" FontWeight="Bold" Foreground="{Binding SettingsVM.NavBarBackground}" Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding CustomFrameworks}" SelectedItem="{Binding SelectedFramework}" DisplayMemberPath="Name" Height="35" Padding="5" FontSize="13"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Student Name:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding CompareStudentName, UpdateSourceTrigger=PropertyChanged}" Height="35" Margin="0,0,0,20" Padding="8" FontSize="13"/>
                        <TextBlock Text="Evaluation Notes:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <Grid Height="120">
                            <TextBox Text="{Binding CompareNotes, UpdateSourceTrigger=PropertyChanged}" SpellCheck.IsEnabled="True" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,15" Padding="8" FontSize="13"/>
                        </Grid>
                        <Grid Margin="0,10,0,25">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="AI Provider 1:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <ComboBox Text="{Binding CompareProvider1}" Height="35" Padding="5" FontSize="13">
                                    <ComboBoxItem Content="Google Gemini"/>
                                    <ComboBoxItem Content="ChatGPT (OpenAI)"/>
                                    <ComboBoxItem Content="Claude (Anthropic)"/>
                                    <ComboBoxItem Content="NVIDIA NIM (Free)"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="AI Provider 2:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <ComboBox Text="{Binding CompareProvider2}" Height="35" Padding="5" FontSize="13">
                                    <ComboBoxItem Content="Google Gemini"/>
                                    <ComboBoxItem Content="ChatGPT (OpenAI)"/>
                                    <ComboBoxItem Content="Claude (Anthropic)"/>
                                    <ComboBoxItem Content="NVIDIA NIM (Free)"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                        <Button Command="{Binding RunComparisonCommand}" Content="Run Comparative Analytics" Height="50" FontSize="14" Style="{StaticResource ModernPrimaryButtonStyle}" />
                    </StackPanel>

                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedNavigationIndex}" Value="3">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,0,10,10">
                                <TextBlock Text="PROFILE &amp; BRANDING" FontWeight="Bold" Foreground="{Binding SettingsVM.NavBarBackground}" Margin="0,0,0,10"/>
                                <CheckBox IsChecked="{Binding SettingsVM.IsDarkMode}" Content="Enable Dark Mode Theme" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,15" />
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Teacher Signature Name:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding SettingsVM.SettingsTeacherName, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="8" FontSize="13"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="School Institution Name:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding SettingsVM.SettingsSchoolName, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="8" FontSize="13"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,25">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Institution Logo (Optional):" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                        <Button Command="{Binding SettingsVM.UploadLogoCommand}" Content="Upload Image (.png/.jpg)" Style="{StaticResource ModernButtonStyle}" Height="35" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Primary Accent Color:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                        <ComboBox SelectedValue="{Binding SettingsVM.SelectedThemeColorHex, Mode=TwoWay}" SelectedValuePath="Tag" Height="35" Padding="8" FontSize="13">
                                            <ComboBoxItem Content="Deep Purple (Default)" Tag="#FF392A4C"/>
                                            <ComboBoxItem Content="Navy Blue" Tag="#FF0A192F"/>
                                            <ComboBoxItem Content="Forest Green" Tag="#FF1B3822"/>
                                            <ComboBoxItem Content="Burgundy Red" Tag="#FF4A1525"/>
                                            <ComboBoxItem Content="Slate Dark" Tag="#FF263238"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="EMAIL CONFIGURATION (SMTP)" FontWeight="Bold" Foreground="{Binding SettingsVM.NavBarBackground}" Margin="0,10,0,10"/>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Sender Email Address:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding SettingsVM.SettingsSmtpEmail, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="8" FontSize="13"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Email App Password:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                        <PasswordBox x:Name="pbSmtpPassword" Height="35" Padding="8" PasswordChanged="PbSmtpPassword_PasswordChanged"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="*IT Warning: Standard passwords will fail. Google Workspace and Microsoft 365 require generating an OAuth 'App Password' for SMTP access." FontStyle="Italic" Foreground="#D32F2F" FontSize="11" Margin="0,0,0,25" TextWrapping="Wrap"/>

                                <TextBlock Text="ADMIN PASSWORD PROTECTION" FontWeight="Bold" Foreground="#F44336" Margin="0,10,0,10"/>
                                <TextBlock Text="Master Settings Password:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <PasswordBox x:Name="pbMasterPassword" Height="35" Padding="8" Margin="0,0,0,10" PasswordChanged="PbMasterPassword_PasswordChanged">
                                    <PasswordBox.Style>
                                        <Style TargetType="PasswordBox">
                                            <Setter Property="Background" Value="{DynamicResource ThemeInputBg}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SettingsVM.DisableMasterPassword}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                    <Setter Property="Opacity" Value="0.5"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </PasswordBox.Style>
                                </PasswordBox>

                                <CheckBox Content="Disable password protection (removes master lock)" 
                                          IsChecked="{Binding SettingsVM.DisableMasterPassword}" 
                                          FontWeight="SemiBold" Foreground="#F44336" Margin="0,0,0,25"/>

                                <Button Command="{Binding SettingsVM.SaveProfileSettingsCommand}" Content="Save System Configurations" Height="45" FontSize="14" Style="{StaticResource ModernPrimaryButtonStyle}" />

                                <TextBlock Text="Your student data is sent securely to your chosen AI provider only to generate the report. It is never stored on external servers or used to train AI models. All local files are encrypted and stored only on this computer." 
                                           TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource ThemeMutedText}" Margin="0,20,0,0" TextAlignment="Center"/>

                            </StackPanel>
                        </ScrollViewer>
                        <Border Background="{DynamicResource ThemeAppBg}" Visibility="{Binding SettingsVM.IsSettingsUnlocked, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}" Panel.ZIndex="10">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                                <TextBlock Text="🔒 Settings Vault Locked" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock Text="Enter your password to access settings." Foreground="{DynamicResource ThemeMutedText}" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                                <PasswordBox x:Name="pbUnlockPassword" Height="40" Width="280" Padding="8" Margin="0,0,0,20" PasswordChanged="PbUnlockPassword_PasswordChanged"/>
                                <Button Command="{Binding SettingsVM.UnlockSettingsCommand}" Content="Unlock Settings" Height="45" Width="280" FontSize="14" Style="{StaticResource ModernPrimaryButtonStyle}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedNavigationIndex}" Value="4">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,0,10,10">
                                <TextBlock Text="AI PROVIDER SETTINGS" FontWeight="Bold" Foreground="{Binding SettingsVM.NavBarBackground}" Margin="0,0,0,10"/>
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Active Core Provider:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                        <ComboBox SelectedValue="{Binding SettingsVM.SelectedAiProvider, Mode=TwoWay}" Height="35">
                                            <ComboBoxItem Content="NVIDIA NIM (Free)"/>
                                            <ComboBoxItem Content="Google Gemini"/>
                                            <ComboBoxItem Content="ChatGPT (OpenAI)"/>
                                            <ComboBoxItem Content="Claude (Anthropic)"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="AI Model Quality:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                        <ComboBox ItemsSource="{Binding SettingsVM.ModelTierOptions}" SelectedValue="{Binding SettingsVM.SelectedModelTier}" SelectedValuePath="Tag" Height="35">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate DataType="{x:Type services:ComboBoxItemWrapper}">
                                                    <TextBlock Text="{Binding Content}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="API Key:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,25">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding SettingsVM.DynamicApiKeyLabel}" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <PasswordBox x:Name="pbApiKey" Grid.Column="1" Height="35" Padding="8" Margin="0,0,10,0" PasswordChanged="PbApiKey_PasswordChanged"/>
                                    <Button Command="{Binding SettingsVM.TestApiCommand}" Grid.Column="2" Content="Test Connection" Style="{StaticResource ModernButtonStyle}" Width="120" Height="35"/>
                                </Grid>

                                <TextBlock Text="CUSTOM WRITING STYLES" FontWeight="Bold" Foreground="{Binding SettingsVM.NavBarBackground}" Margin="0,10,0,10"/>
                                <TextBlock Text="Style Name (e.g. SEN Friendly):" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding SettingsVM.SettingsNewFrameworkName, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="8" Margin="0,0,0,15" FontSize="13"/>
                                <TextBlock Text="Instructions for this writing style:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding SettingsVM.SettingsNewFrameworkInstruction, UpdateSourceTrigger=PropertyChanged}" SpellCheck.IsEnabled="True" TextWrapping="Wrap" AcceptsReturn="True" Height="70" Padding="8" Margin="0,0,0,10" FontSize="13"/>
                                <Button Command="{Binding SettingsVM.AddFrameworkCommand}" Content="Add Writing Style" Style="{StaticResource ModernButtonStyle}" Height="35" Margin="0,0,0,25"/>

                                <Button Command="{Binding SettingsVM.SaveProfileSettingsCommand}" Content="Save AI Configurations" Height="45" FontSize="14" Style="{StaticResource ModernPrimaryButtonStyle}" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedNavigationIndex}" Value="5">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>
                        <StackPanel Margin="0,0,10,10">
                            <TextBlock Text="YOUR TIME SAVINGS" FontWeight="Bold" Foreground="{Binding SettingsVM.NavBarBackground}" Margin="0,10,0,10"/>
                            <TextBlock Text="Labor metrics reflected reduction in administrative load hours saved through automated generation systems." Foreground="{DynamicResource ThemeMutedText}" TextWrapping="Wrap" FontSize="13" Margin="0,0,0,15"/>
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}" Background="#E8EAF6" Margin="0,0,5,0">
                                    <StackPanel>
                                        <TextBlock Text="Saved Labor Hours" FontSize="14" FontWeight="SemiBold" Foreground="{Binding SettingsVM.NavBarBackground}"/>
                                        <TextBlock Text="{Binding HoursSavedDisplay}" FontSize="32" FontWeight="Bold" Foreground="{Binding SettingsVM.NavBarBackground}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}" Background="#E8F5E9" Margin="5,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Estimated Token Output" FontSize="14" FontWeight="SemiBold" Foreground="{Binding SettingsVM.NavBarBackground}"/>
                                        <TextBlock Text="{Binding TokensUsedDisplay}" FontSize="32" FontWeight="Bold" Foreground="{Binding SettingsVM.NavBarBackground}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <TextBlock Text="REPORTS BY AI PROVIDER" FontWeight="Bold" Foreground="{Binding SettingsVM.NavBarBackground}" Margin="0,10,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}" Background="#E1F5FE">
                                    <StackPanel>
                                        <TextBlock Text="NVIDIA" FontSize="11" Foreground="#0277BD"/>
                                        <TextBlock Text="{Binding NvidiaCountDisplay}" FontSize="20" FontWeight="Bold" Foreground="#01579B"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}" Background="#E0F7FA">
                                    <StackPanel>
                                        <TextBlock Text="Gemini" FontSize="11" Foreground="#00838F"/>
                                        <TextBlock Text="{Binding GeminiCountDisplay}" FontSize="20" FontWeight="Bold" Foreground="#006064"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}" Background="#F3E5F5">
                                    <StackPanel>
                                        <TextBlock Text="OpenAI" FontSize="11" Foreground="#6A1B9A"/>
                                        <TextBlock Text="{Binding OpenaiCountDisplay}" FontSize="20" FontWeight="Bold" Foreground="#4A148C"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="3" Style="{StaticResource MetricCardStyle}" Background="#FFF3E0">
                                    <StackPanel>
                                        <TextBlock Text="Claude" FontSize="11" Foreground="#EF6C00"/>
                                        <TextBlock Text="{Binding ClaudeCountDisplay}" FontSize="20" FontWeight="Bold" Foreground="#E65100"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource ModernCardStyle}" x:Name="Card2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="REPORT PREVIEW" FontWeight="Bold" FontSize="16" Foreground="{Binding SettingsVM.NavBarBackground}"/>
                    <TextBlock Text="{Binding StatusText}" FontSize="12" Margin="0,4,0,0" Foreground="{DynamicResource ThemeMutedText}"/>
                    <ProgressBar Height="4" IsIndeterminate="True" Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVis}}" Margin="0,10,0,0" Foreground="{Binding SettingsVM.NavBarBackground}" Background="Transparent" BorderThickness="0"/>
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Text="{Binding GeneratedReportOutput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="0" TextWrapping="Wrap" AcceptsReturn="True" FontSize="14" Padding="15">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Setter Property="Grid.ColumnSpan" Value="1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCompareRightVisible}" Value="False">
                                        <Setter Property="Grid.ColumnSpan" Value="2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <TextBox Text="{Binding CompareOutputRight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Background="{DynamicResource ThemePreviewBg}" Grid.Column="1" Margin="10,0,0,0" TextWrapping="Wrap" AcceptsReturn="True" FontSize="14" Padding="15" Visibility="{Binding IsCompareRightVisible, Converter={StaticResource BoolToVis}}"/>
                </Grid>

                <WrapPanel Grid.Row="2" HorizontalAlignment="Right">
                    <Button Command="{Binding UpdateHistoryEditCommand}" Content="💾 Save Edits" Style="{StaticResource ModernButtonStyle}" Background="#E8F5E9" Foreground="#2E7D32" Margin="5,5,0,0" />
                    <Button Command="{Binding CopyReportCommand}" Content="📋 Copy Text" Style="{StaticResource ModernButtonStyle}" Margin="5,5,0,0" />
                    <Button Command="{Binding EmailReportCommand}" Content="✉️ Email Parent" Style="{StaticResource ModernButtonStyle}" Background="#FFFFE0B2" Foreground="#FFE65100" Margin="5,5,0,0" />
                    <Button Command="{Binding SavePdfCommand}" Content="Export PDF" Style="{StaticResource ModernPrimaryButtonStyle}" Background="#FFF44336" Margin="5,5,0,0" />
                    <Button Command="{Binding SaveWordCommand}" Content="Export Word (.docx)" Style="{StaticResource ModernPrimaryButtonStyle}" Background="#FF1976D2" Margin="5,5,0,0" />
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource ModernCardStyle}" x:Name="Card3">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1.5*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="HISTORY LOG" FontWeight="Bold" FontSize="16" Foreground="{Binding SettingsVM.NavBarBackground}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <TextBox Grid.Column="1" Text="{Binding HistorySearchText, UpdateSourceTrigger=PropertyChanged}" Height="30" Padding="8,4" FontSize="13" ToolTip="Search by student name or keywords..." Margin="0,0,10,0"/>
                        <Button Command="{Binding ShowAllHistoryCommand}" Grid.Column="2" Content="Clear Filter" Style="{StaticResource ModernButtonStyle}" Height="30" Padding="10,0" />
                    </Grid>
                    <TextBlock Text="past reports." FontSize="12" Margin="0,4,0,10" Foreground="{DynamicResource ThemeMutedText}"/>
                </StackPanel>

                <ListBox ItemsSource="{Binding SessionHistory}" 
                         SelectedItem="{Binding SelectedHistoryItem}" 
                         DisplayMemberPath="DisplayText" 
                         Grid.Row="1" FontSize="14" Margin="0,0,0,15">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu>
                                        <MenuItem Header="Delete Record" 
                                                  Command="{Binding PlacementTarget.Tag.DeleteHistoryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <Grid Grid.Row="2" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="HISTORY SNAPSHOT" FontWeight="Bold" FontSize="11" Foreground="{DynamicResource ThemeMutedText}" VerticalAlignment="Center"/>
                    <Button Command="{Binding CompareHistoryCommand}" Grid.Column="1" Content="Compare w/ Editor" Style="{StaticResource ModernButtonStyle}" Height="25" Padding="10,0" />
                </Grid>

                <TextBox Text="{Binding SelectedHistoryItem.GeneratedReport, Mode=OneWay}" Background="{DynamicResource ThemePreviewBg}" Grid.Row="3" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True" FontSize="13" Padding="15"/>
            </Grid>
        </Border>

        <Border x:Name="overlayWelcome" Visibility="{Binding IsWelcomeOverlayVisible, Converter={StaticResource BoolToVis}}" Grid.Row="0" Grid.RowSpan="2" Grid.ColumnSpan="3" Background="#F2000000" Panel.ZIndex="100">
            <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="12" Width="720" Height="580" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="35">
                <StackPanel>
                    <TextBlock Text="👋 Welcome to AI Student Report Generator" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource ThemeText}" TextAlignment="Center" Margin="0,0,0,10"/>

                    <StackPanel Visibility="{Binding IsProfileSetupVisible, Converter={StaticResource BoolToVis}}" Margin="0,5,0,15">
                        <TextBlock Text="Configure teacher signature contexts details here." FontSize="14" Foreground="{DynamicResource ThemeMutedText}" TextAlignment="Center" Margin="0,0,0,15"/>
                        <Grid Width="380" HorizontalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Teacher Signature (e.g. Mr. Smith):" FontWeight="SemiBold" Margin="0,0,0,5" Grid.Row="0"/>
                            <TextBox Text="{Binding SettingsVM.SettingsTeacherName, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="8" FontSize="14" Margin="0,0,0,12" Grid.Row="1"/>
                            <TextBlock Text="School Institution Name:" FontWeight="SemiBold" Margin="0,0,0,5" Grid.Row="2"/>
                            <TextBox Text="{Binding SettingsVM.SettingsSchoolName, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="8" FontSize="14" Grid.Row="3"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Visibility="{Binding IsWelcomeBackVisible, Converter={StaticResource BoolToVis}}" Margin="0,10,0,15">
                        <TextBlock Text="System Active &amp; Ready!" FontSize="20" FontWeight="Bold" Foreground="#4CAF50" TextAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock Text="Everything is set up and ready to go" FontSize="14" Foreground="{DynamicResource ThemeMutedText}" TextAlignment="Center" Margin="0,0,0,10"/>
                        <Button Command="{Binding EditWelcomeProfileCommand}" Content="Edit Administrative Profile Properties" Style="{StaticResource ModernButtonStyle}" Background="Transparent" Foreground="{Binding SettingsVM.NavBarBackground}" Height="25" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Grid Margin="0,5,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="5">
                            <TextBlock Text="⚙️ Configuration" FontSize="16" FontWeight="Bold" Foreground="#2196F3" TextAlignment="Center" Margin="0,0,0,5"/>
                            <TextBlock Text="Enter your AI provider key in settings to get started." Foreground="{DynamicResource ThemeText}" TextWrapping="Wrap" TextAlignment="Center" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5">
                            <TextBlock Text="📝 Aggregation" FontSize="16" FontWeight="Bold" Foreground="#4CAF50" TextAlignment="Center" Margin="0,0,0,5"/>
                            <TextBlock Text="Add your students and subjects to your student list." Foreground="{DynamicResource ThemeText}" TextWrapping="Wrap" TextAlignment="Center" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="5">
                            <TextBlock Text="🚀 Optimization" FontSize="16" FontWeight="Bold" Foreground="#FF9800" TextAlignment="Center" Margin="0,0,0,5"/>
                            <TextBlock Text="Generate reports for your whole class at once" Foreground="{DynamicResource ThemeText}" TextWrapping="Wrap" TextAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                    <Border Background="#FFF3E0" CornerRadius="8" Padding="12" Margin="0,0,0,20">
                        <TextBlock Text="Your student data is sent securely to your chosen AI provider only to generate the report. It is never stored on external servers or used to train AI models. All local files are encrypted and stored only on this computer." TextWrapping="Wrap" Foreground="#E65100" FontWeight="SemiBold" TextAlignment="Center" FontSize="11"/>
                    </Border>
                    <Grid>
                        <Button Command="{Binding EnterAppCommand}" Content="Get Started" Height="45" Width="360" FontSize="15" Style="{StaticResource ModernPrimaryButtonStyle}" HorizontalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>